{
  "info": {
    "name": "Presupuesto Personal - API",
    "description": "Colección de pruebas para el Sistema de Gestión de Presupuesto Personal (Proyecto 9). Cubre los 5 requerimientos funcionales: RF1 (ingresos), RF2 (gastos), RF3 (categorías), RF4 (reportes), RF5 (alertas de presupuesto).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "usuario_id", "value": "1" }
  ],
  "item": [

    {
      "name": "👤 Usuarios",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/registro", "host": ["{{base_url}}"], "path": ["api","usuarios","registro"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Carlos Mendoza\",\n  \"email\": \"carlos@email.com\",\n  \"password\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "Buscar usuario por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api","usuarios","{{usuario_id}}"] }
          }
        },
        {
          "name": "Buscar usuario por email",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/usuarios/email/juan@email.com", "host": ["{{base_url}}"], "path": ["api","usuarios","email","juan@email.com"] }
          }
        },
        {
          "name": "Actualizar usuario",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/usuarios/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api","usuarios","{{usuario_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez Actualizado\",\n  \"email\": \"juan@email.com\",\n  \"password\": \"nueva1234\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "🏷️ Categorías (RF3)",
      "item": [
        {
          "name": "Listar categorías de un usuario",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/categorias/usuario/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api","categorias","usuario","{{usuario_id}}"] }
          }
        },
        {
          "name": "Listar categorías por tipo - GASTO",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/categorias/usuario/{{usuario_id}}/tipo/GASTO", "host": ["{{base_url}}"], "path": ["api","categorias","usuario","{{usuario_id}}","tipo","GASTO"] }
          }
        },
        {
          "name": "Listar categorías por tipo - INGRESO",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/categorias/usuario/{{usuario_id}}/tipo/INGRESO", "host": ["{{base_url}}"], "path": ["api","categorias","usuario","{{usuario_id}}","tipo","INGRESO"] }
          }
        },
        {
          "name": "Crear categoría",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/categorias", "host": ["{{base_url}}"], "path": ["api","categorias"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Salud\",\n  \"tipo\": \"GASTO\",\n  \"descripcion\": \"Medicamentos y consultas médicas\",\n  \"usuario\": { \"id\": 1 }\n}"
            }
          }
        },
        {
          "name": "Actualizar categoría",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/categorias/3", "host": ["{{base_url}}"], "path": ["api","categorias","3"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Alimentación y Mercado\",\n  \"tipo\": \"GASTO\",\n  \"descripcion\": \"Gastos en comida, mercado y restaurantes\",\n  \"usuario\": { \"id\": 1 }\n}"
            }
          }
        },
        {
          "name": "Eliminar categoría",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/categorias/3", "host": ["{{base_url}}"], "path": ["api","categorias","3"] }
          }
        }
      ]
    },

    {
      "name": "💰 Transacciones (RF1 y RF2)",
      "item": [
        {
          "name": "Listar todas las transacciones de un usuario",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/transacciones/usuario/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api","transacciones","usuario","{{usuario_id}}"] }
          }
        },
        {
          "name": "Listar transacciones por tipo - INGRESO",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/transacciones/usuario/{{usuario_id}}/tipo/INGRESO", "host": ["{{base_url}}"], "path": ["api","transacciones","usuario","{{usuario_id}}","tipo","INGRESO"] }
          }
        },
        {
          "name": "Listar transacciones por tipo - GASTO",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/transacciones/usuario/{{usuario_id}}/tipo/GASTO", "host": ["{{base_url}}"], "path": ["api","transacciones","usuario","{{usuario_id}}","tipo","GASTO"] }
          }
        },
        {
          "name": "Listar transacciones por rango de fechas (RF4)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/transacciones/usuario/{{usuario_id}}/rango?fechaInicio=2025-06-01&fechaFin=2025-06-30",
              "host": ["{{base_url}}"],
              "path": ["api","transacciones","usuario","{{usuario_id}}","rango"],
              "query": [
                { "key": "fechaInicio", "value": "2025-06-01" },
                { "key": "fechaFin", "value": "2025-06-30" }
              ]
            }
          }
        },
        {
          "name": "Registrar ingreso (RF1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/transacciones", "host": ["{{base_url}}"], "path": ["api","transacciones"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto\": 3500.00,\n  \"tipo\": \"INGRESO\",\n  \"descripcion\": \"Sueldo julio 2025\",\n  \"fechaTransaccion\": \"2025-07-01\",\n  \"usuario\": { \"id\": 1 },\n  \"categoria\": { \"id\": 1 }\n}"
            }
          }
        },
        {
          "name": "Registrar gasto (RF2)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/transacciones", "host": ["{{base_url}}"], "path": ["api","transacciones"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto\": 180.00,\n  \"tipo\": \"GASTO\",\n  \"descripcion\": \"Supermercado semana 1\",\n  \"fechaTransaccion\": \"2025-07-03\",\n  \"usuario\": { \"id\": 1 },\n  \"categoria\": { \"id\": 3 }\n}"
            }
          }
        },
        {
          "name": "Actualizar transacción",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/transacciones/1", "host": ["{{base_url}}"], "path": ["api","transacciones","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monto\": 3800.00,\n  \"tipo\": \"INGRESO\",\n  \"descripcion\": \"Sueldo Junio corregido\",\n  \"fechaTransaccion\": \"2025-06-01\",\n  \"usuario\": { \"id\": 1 },\n  \"categoria\": { \"id\": 1 }\n}"
            }
          }
        },
        {
          "name": "Eliminar transacción",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/transacciones/1", "host": ["{{base_url}}"], "path": ["api","transacciones","1"] }
          }
        }
      ]
    },

    {
      "name": "📊 Presupuestos (RF5)",
      "item": [
        {
          "name": "Listar presupuestos de un usuario",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/presupuestos/usuario/{{usuario_id}}", "host": ["{{base_url}}"], "path": ["api","presupuestos","usuario","{{usuario_id}}"] }
          }
        },
        {
          "name": "Listar presupuestos por mes y año",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/presupuestos/usuario/{{usuario_id}}/mes/6/anio/2025", "host": ["{{base_url}}"], "path": ["api","presupuestos","usuario","{{usuario_id}}","mes","6","anio","2025"] }
          }
        },
        {
          "name": "Buscar presupuesto por ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/presupuestos/1", "host": ["{{base_url}}"], "path": ["api","presupuestos","1"] }
          }
        },
        {
          "name": "Crear presupuesto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/presupuestos", "host": ["{{base_url}}"], "path": ["api","presupuestos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"montoMaximo\": 500.00,\n  \"mes\": 7,\n  \"anio\": 2025,\n  \"usuario\": { \"id\": 1 },\n  \"categoria\": { \"id\": 3 }\n}"
            }
          }
        },
        {
          "name": "Crear presupuesto DUPLICADO (debe fallar - RF5)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/presupuestos", "host": ["{{base_url}}"], "path": ["api","presupuestos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"montoMaximo\": 300.00,\n  \"mes\": 6,\n  \"anio\": 2025,\n  \"usuario\": { \"id\": 1 },\n  \"categoria\": { \"id\": 3 }\n}"
            }
          }
        },
        {
          "name": "Actualizar presupuesto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/presupuestos/1", "host": ["{{base_url}}"], "path": ["api","presupuestos","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"montoMaximo\": 600.00,\n  \"mes\": 6,\n  \"anio\": 2025,\n  \"usuario\": { \"id\": 1 },\n  \"categoria\": { \"id\": 3 }\n}"
            }
          }
        },
        {
          "name": "Eliminar presupuesto",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/presupuestos/1", "host": ["{{base_url}}"], "path": ["api","presupuestos","1"] }
          }
        }
      ]
    },

    {
      "name": "📈 Reportes (RF4)",
      "item": [
        {
          "name": "Reporte mensual - Junio 2025",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/reportes/mensual?idUsuario={{usuario_id}}&mes=6&anio=2025",
              "host": ["{{base_url}}"],
              "path": ["api","reportes","mensual"],
              "query": [
                { "key": "idUsuario", "value": "{{usuario_id}}" },
                { "key": "mes", "value": "6" },
                { "key": "anio", "value": "2025" }
              ]
            }
          }
        },
        {
          "name": "Reporte mensual - Mayo 2025",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/reportes/mensual?idUsuario={{usuario_id}}&mes=5&anio=2025",
              "host": ["{{base_url}}"],
              "path": ["api","reportes","mensual"],
              "query": [
                { "key": "idUsuario", "value": "{{usuario_id}}" },
                { "key": "mes", "value": "5" },
                { "key": "anio", "value": "2025" }
              ]
            }
          }
        },
        {
          "name": "Reporte mensual - usuario 2 (Ana)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/reportes/mensual?idUsuario=2&mes=6&anio=2025",
              "host": ["{{base_url}}"],
              "path": ["api","reportes","mensual"],
              "query": [
                { "key": "idUsuario", "value": "2" },
                { "key": "mes", "value": "6" },
                { "key": "anio", "value": "2025" }
              ]
            }
          }
        }
      ]
    }

  ]
}
